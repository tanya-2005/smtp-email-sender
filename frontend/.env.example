# Must be set to your backend API's URL - there is no built-in fallback.
# Vite inlines VITE_ vars at build time, so this must be set before running
# `vite dev` or `vite build` (and in your deployment platform's env vars
# for hosted builds, e.g. Vercel project settings).
VITE_API_BASE_URL=https://smtp-email-sender-production.up.railway.app/api
