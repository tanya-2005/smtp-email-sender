PORT=3000
NODE_ENV=development

# Gmail SMTP settings. SMTP_PASS must be a 16-character Google App Password,
# not your regular Gmail password. Requires 2-Step Verification enabled on
# the account: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="Your App <your_gmail_address@gmail.com>"
